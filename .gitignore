# macOS
.DS_Store

# Editors
.idea/
.vscode/
*.swp
*.swo

# Vercel — local project link (contains org/project IDs, regenerated on `vercel link`)
.vercel/

# Logs
*.log
.npm
.cache/

# Node — local install only; Vercel rebuilds from package-lock.json
node_modules/

# Local env file (never commit secrets — set them in Vercel dashboard)
.env
.env.local

# Temp
*.bak

# Image backups — original full-size sources kept locally before WebP conversion.
# (The originals also remain in git history from earlier commits, so they're
# recoverable; no need to bloat the repo with them again. Excluded from deploy
# via .vercelignore too.)
assets/_originals/
